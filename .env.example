# ── NVIDIA NIM Gateway — Environment Variables ─────────────────────────
# Copy to .env and fill in your values.

# NVIDIA NIM API key (used by default provider config)
NVIDIA_NIM_API_KEY=nvgw_YOUR_NIM_API_KEY_HERE

# Gateway overrides
NIM_GW_LOG_LEVEL=INFO
NIM_GW_HOST=0.0.0.0
NIM_GW_PORT=8000
NIM_GW_CONFIG_DIR=./config

# API key validation
NIM_GW_API_KEY_ENABLED=true

# OpenTelemetry (optional)
NIM_GW_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces

# Grafana (optional, for docker compose)
GRAFANA_PASSWORD=admin

# Docker Compose project name
COMPOSE_PROJECT_NAME=nvidia-nim-gateway
